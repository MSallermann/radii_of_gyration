    input:
        f"{myconfig.results_folder}/aggregated_rg.csv"

rule mpipi:
    input:
        rules.mpipi_prepare.input,
        rules.mpipi_run.input,
        rules.mpipi_avg.input,
        rules.mpipi_aggregate.input,
        rules.mpipi_avg_rij.input

rule calvados:
    input:
        f"{myconfig.results_folder}/aggregated_rg_calvados.csv"

