rule prepare_coarse_grained_inputs:
    localrule: True
    input:
        template_file=ancient(myconfig.lammps_script_template),
    shadow:
        "copy-minimal"
    threads: 1
    output:
        data_file=f"{myconfig.results_folder}/lammps_files/{{sample}}/data_file.data",
        script=f"{myconfig.results_folder}/lammps_files/{{sample}}/script.lmp",
        globular_domains_file=f"{myconfig.results_folder}/lammps_files/{{sample}}/domains.json",
    params:
        temp=get_temp,
        press=get_press,
        ionic_strength=get_ionic_strength,
        prot_data=get_prot_data,
        threshold=get_threshold,
        start_idx=get_start_idx,
        end_idx=get_end_idx,
        domain_indices=get_domain_indices,
        n_steps=myconfig.n_steps,
        timestep=myconfig.timestep,
        minimum_domain_length=myconfig.minimum_domain_length,
        minimum_idr_length=myconfig.minimum_idr_length,
        min_pae_cutoff=myconfig.min_pae_cutoff,
        mean_pae_cutoff=myconfig.mean_pae_cutoff,
        min_distance_cutoff=myconfig.min_distance_cutoff,
        max_coordination_cutoff=myconfig.max_coordination_cutoff,
        coordination_distance_cutoff=myconfig.coordination_distance_cutoff,
        box_buffer=myconfig.box_buffer,
        glob_glob_rescaling=myconfig.glob_glob_rescaling,
        idr_glob_rescaling=myconfig.idr_glob_rescaling,
        residue_location=myconfig.residue_location,
        n_save_rg=myconfig.n_save_rg,
        n_save_traj=myconfig.n_save_traj,
        n_save_density=myconfig.n_save_density,
        nvt_seed=myconfig.nvt_seed,
        n_proteins_x=get_n_proteins_x,
        n_proteins_y=get_n_proteins_y,
        n_proteins_z=get_n_proteins_z,
        intermediate_pressure=myconfig.intermediate_pressure,
        n_steps_intermediate_pressure=myconfig.n_steps_intermediate_pressure,
        use_berendsen_npt=myconfig.use_berendsen_npt,
        fuse_seq=myconfig.fuse_seq,
        fuse_merge=myconfig.fuse_merge,
    script:
        workflow.source_path("scripts/coarse_grain_with_glob_scaling.py")


def get_n_threads(wildcards):
    if myconfig.n_cores_lammps is not None:
        return myconfig.n_cores_lammps

    start_idx = get_start_idx(wildcards)
    end_idx = get_end_idx(wildcards)

    if start_idx is not None and end_idx is not None:
        n_res = end_idx - start_idx
    elif (prot_data := get_prot_data(wildcards)) is not None:
        n_res = len(prot_data["sequence_one_letter"])
    else:
        return 1

    n_threads = n_res // 300 + 1
    return int(min(max(2, n_threads), 6))


rule run_lammps:
    input:
        # rules.prepare_coarse_grained_inputs.output
        data_file=f"{myconfig.results_folder}/lammps_files/{{sample}}/data_file.data",
        script=f"{myconfig.results_folder}/lammps_files/{{sample}}/script.lmp",
    output:
        traj=f"{myconfig.results_folder}/lammps_runs/{{sample}}/result.lammpstrj",
        gyration=f"{myconfig.results_folder}/lammps_runs/{{sample}}/gyration.out",
        log=f"{myconfig.results_folder}/lammps_runs/{{sample}}/log.lammps",
    threads: get_n_threads
    params:
        workdir=lambda wc: f"{myconfig.results_folder}/lammps_runs/{wc.sample}",
    resources:
        nodes=1,
        ntasks_per_node=get_n_threads,
        cpus_per_task=1,
        slurm_out=lambda wc: f"{myconfig.results_folder}/lammps_files/{wc.sample}/slurm.out",
        slurm_err=lambda wc: f"{myconfig.results_folder}/lammps_files/{wc.sample}/slurm.err",
    shell:
        "cp -r {input.script} {params.workdir}\n"
        "cp -r {input.data_file} {params.workdir}\n"
        "cd {params.workdir}\n"
        "export OMP_NUM_THREADS={resources.cpus_per_task}\n"
        f"{myconfig.lammps_binary} -in script.lmp\n"

rule analyse_log:
    localrule: True
    input:
        f"{myconfig.results_folder}/lammps_runs/{{sample}}/log.lammps"
    output:
        f"{myconfig.results_folder}/log_data/{{sample}}/avg.json"
    params:
        n_skip= myconfig.log_skip,
    script:
        workflow.source_path("scripts/analyse_lammps_log.py")


rule average_radius_of_gyration:
    localrule: True
    input:
        f"{myconfig.results_folder}/lammps_runs/{{sample}}/gyration.out",
    output:
        rg_json=f"{myconfig.results_folder}/rg/{{sample}}/rg.json",
    params:
        n_skip=int(myconfig.rg_skip),
    script:
        workflow.source_path("scripts/average_radius_of_gyration.py")


rule average_pair_distance:
    localrule: True
    input:
        lammps_data_file=f"{myconfig.results_folder}/lammps_files/{{sample}}/data_file.data",
        lammps_traj_file=f"{myconfig.results_folder}/lammps_runs/{{sample}}/result.lammpstrj",
        globular_domains_file=f"{myconfig.results_folder}/lammps_files/{{sample}}/domains.json"
    params:
        n_skip=myconfig.rij_skip,
        use_graph_distance=myconfig.use_rij_graph_distance,
        prot_data=get_prot_data
    output:
        output_csv = f"{myconfig.results_folder}/rij/{{sample}}/pair_distances.csv",
        output_json = f"{myconfig.results_folder}/rij/{{sample}}/rij.json",
    script:
        workflow.source_path("scripts/average_residue_distance.py")

### This last rule simply tries to collect all rg values
KEYS = set()
for samp in SAMPLES.values():
    KEYS.update(samp.keys())

added_columns = {key: [sample.get(key) for sample in SAMPLES.values()] for key in KEYS}


rule aggregate_rg:
    localrule: True
    threads: 1
    input:
        [f"{myconfig.results_folder}/rg/{sample}/rg.json" for sample in SAMPLES.keys()],
    params:
        add_columns={**added_columns},
        ignore_columns=["file"],
    output:
        f"{myconfig.results_folder}/aggregated_rg.csv",
    script:
        workflow.source_path("scripts/aggregate_json.py")


