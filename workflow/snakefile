import polars as pl
from pathlib import Path
import itertools
import json
from dataclasses import dataclass, asdict
import functools
import logging

configfile: "config.yml"

######################################################################
# Parse some information from the config.yml.file
######################################################################

@dataclass
class MyConfig:
    database_file : str
    samples_file : str

    lammps_binary : str | None
    lammps_script_template : str | None

    n_steps : int
    timestep : float
    rg_skip : int
    rij_skip : int
    log_skip : int
    box_buffer : float

    n_save_rg : int
    n_save_traj : int

    domains_file : str | None = None

    use_rij_graph_distance : bool = True

    temperature : float | None = None
    ionic_strength : float | None = None

    pressure : float | None = None
    use_berendsen_npt : bool = False
    intermediate_pressure : float | None = None
    n_steps_intermediate_pressure : int | None = None

    n_save_density : int = 200000

    n_cores_lammps : int | None = None

    samples_start_idx : int = 0
    samples_end_idx : int | None = None

    minimum_domain_length : int = 0
    minimum_idr_length : int = 0

    threshold : float | None = None

    min_pae_cutoff : float | None = None
    mean_pae_cutoff : float | None = None
    min_distance_cutoff : float | None = None
    max_coordination_cutoff : int | None = None
    coordination_distance_cutoff : float | None = None
    fuse_seq : bool = False
    fuse_merge : bool = False

    glob_glob_rescaling : float = 1.0
    idr_glob_rescaling : float = 1.0

    residue_location : str | None = "Ca"
    calvados_residues_file : str | None = None

    nvt_seed: int = 34278

    n_proteins_x : int = 1
    n_proteins_y : int = 1
    n_proteins_z : int = 1

    results_folder : str = "results"

myconfig = MyConfig(**config)

######################################################################
# The database file from which the prot_data dicts are read in 
######################################################################

database_file = Path(myconfig.database_file)
if database_file.suffix == ".parquet":
    DATA_BASE = (
        pl.scan_parquet(database_file).select("key", "prot_data").collect()
    )
else:
    DATA_BASE = (
        pl.scan_ipc(database_file).select("key", "prot_data").collect()
    )


######################################################################
# Read in the domains file
######################################################################

if myconfig.domains_file is not None:
    domains_file = Path(myconfig.domains_file)
    with domains_file.open("r") as f:
        DOMAINS = json.load(f)
else:
    DOMAINS = None

######################################################################
# Read in the samples file
######################################################################

with open(myconfig.samples_file, "rb") as f:
    SAMPLES = json.load(f)

SAMPLES_START_IDX = myconfig.samples_start_idx
SAMPLES_END_IDX = myconfig.samples_end_idx if myconfig.samples_end_idx is not None else len(SAMPLES)


print(f"Read {len(SAMPLES)} samples from {myconfig.samples_file}")
print(f"{SAMPLES_START_IDX = }")
print(f"{SAMPLES_END_IDX = }")

drop_idx = []
for idx, k in enumerate(SAMPLES):
    if idx >= SAMPLES_START_IDX and idx<SAMPLES_END_IDX:
        continue
    else:
        drop_idx.append(k)

[SAMPLES.pop(idx) for idx in drop_idx]

######################################################################
# Define some utility functions
######################################################################

def get_db_row(wc):
    key = SAMPLES[wc.sample]["db_key"]
    db_filtered = DATA_BASE.filter(pl.col("key") == key)

    if len(db_filtered) != 1:
        msg = f"The key '{key}' has {len(db_filtered)} entries in the database. For correct operation, it needs to be *exactly* one!"
        raise Exception(msg)

    return db_filtered.row(0, named=True)


def get_prot_data(wc):
    return get_db_row(wc).get("prot_data")


@dataclass
class Sample:
    db_key:str
    temperature:float
    ionic_strength:float
    threshold:float
    tc:float | None = None
    start_idx : int |None = None
    end_idx : int | None = None
    domain_indices : list[list[tuple[int,int]]] | None = None
    pressure: float | None = None
    n_proteins_x : int | None = None
    n_proteins_y : int | None = None
    n_proteins_z : int | None = None

def get_sample(wc) -> Sample:
    return Sample(**SAMPLES[wc.sample])

def get_attr_from_sample_or_config(wc, attr:str, fallback:bool=False, warn_if_none:bool=True):
    samp = get_sample(wc)
    assert hasattr(samp, attr)

    if fallback:
        if not hasattr(myconfig, attr):
            msg = f"You tried to use the attribute `{attr}`, with fallback=true. But `{attr}` is not a member of the `MyConfig` data class."
            raise Exception(msg)

    attr_from_sample = getattr(samp, attr)

    # Look in the config as a fallback
    if attr_from_sample is None and fallback:
        attr_from_config = getattr(myconfig, attr)
        if attr_from_config is None and warn_if_none:
            logging.warning(f"{wc.sample}: Looked in sample and in config, but {attr} is still None")
        return attr_from_config

    return attr_from_sample

get_temp = functools.partial(get_attr_from_sample_or_config, attr="temperature", fallback=True)
get_press = functools.partial(get_attr_from_sample_or_config, attr="pressure", fallback=True, warn_if_none=False) # pressure is allowed to be none
get_ionic_strength = functools.partial(get_attr_from_sample_or_config, attr="ionic_strength", fallback=True)
get_threshold = functools.partial(get_attr_from_sample_or_config, attr="threshold", fallback=True)
get_n_proteins_x = functools.partial(get_attr_from_sample_or_config, attr="n_proteins_x", fallback=True)
get_n_proteins_y = functools.partial(get_attr_from_sample_or_config, attr="n_proteins_y", fallback=True)
get_n_proteins_z = functools.partial(get_attr_from_sample_or_config, attr="n_proteins_z", fallback=True)
get_start_idx = functools.partial(get_attr_from_sample_or_config, attr="start_idx")
get_end_idx = functools.partial(get_attr_from_sample_or_config, attr="end_idx")

def get_domain_indices(wc):
    samp = get_sample(wc)

    domain_indices = samp.domain_indices

    if domain_indices is None:
        domain_indices = DOMAINS.get(samp.db_key)

    return domain_indices

